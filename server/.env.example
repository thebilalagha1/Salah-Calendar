# Copy this file to .env and fill in real values. Never commit .env.

# From Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client ID (Web application)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Long random string used to sign session JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# The URL your React client runs on (used for CORS). Include protocol, no trailing slash.
CLIENT_URL=http://localhost:5173

# Port the API server listens on
PORT=8787

# Set to "true" when serving over HTTPS in production so the session cookie
# is marked Secure. Keep "false" for local http development.
COOKIE_SECURE=false
